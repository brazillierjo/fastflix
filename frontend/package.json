{
  "name": "fastflix",
  "main": "expo-router/entry",
  "version": "3.1.1",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0",
    "lint:warnings": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "version:patch": "node scripts/version-bump.js patch",
    "version:minor": "node scripts/version-bump.js minor",
    "version:major": "node scripts/version-bump.js major",
    "version:set": "node scripts/version-bump.js set",
    "version:status": "node scripts/version-bump.js status",
    "build:ios": "node scripts/version-bump.js build-ios",
    "build:android": "node scripts/version-bump.js build-android",
    "build:both": "node scripts/version-bump.js build-both",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit 2>&1 | grep -Ev 'Force exiting Jest|worker process has failed to exit gracefully|--detectOpenHandles|Active timers' || true",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit 2>&1 | grep -Ev 'Force exiting Jest|worker process has failed|--detectOpenHandles|Active timers' || true",
    "test:ci": "jest --ci --coverage --watchAll=false --forceExit 2>&1 | grep -Ev 'Force exiting Jest|worker process has failed|--detectOpenHandles|Active timers' || true",
    "pre-commit": "npm run lint && npm run format:check && npm run typecheck && npm run test:ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@aptabase/react-native": "^0.4.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.80.6",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "expo": "^54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "moti": "^0.30.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-purchases": "^8.11.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.7.4",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@testing-library/react-native": "^13.2.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "knip": "^5.70.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
