#!/bin/sh

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Check which packages changed
BACKEND_CHANGED=$(echo "$STAGED_FILES" | grep -c "^backend/" || true)
FRONTEND_CHANGED=$(echo "$STAGED_FILES" | grep -c "^frontend/" || true)
WEBSITE_CHANGED=$(echo "$STAGED_FILES" | grep -c "^website/" || true)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "🔍 Running pre-commit checks..."
echo ""

# Backend checks
if [ "$BACKEND_CHANGED" -gt 0 ]; then
    echo "${YELLOW}📦 Backend changes detected - running checks...${NC}"

    cd backend

    echo "  → Running type check..."
    if ! npm run typecheck; then
        echo "${RED}❌ Backend type check failed${NC}"
        exit 1
    fi

    echo "  → Running lint..."
    if ! npm run lint; then
        echo "${RED}❌ Backend lint failed${NC}"
        exit 1
    fi

    echo "  → Running format check..."
    if ! npm run format:check; then
        echo "${RED}❌ Backend format check failed${NC}"
        echo "  Run 'cd backend && npm run format' to fix"
        exit 1
    fi

    echo "  → Running tests..."
    if ! npm run test; then
        echo "${RED}❌ Backend tests failed${NC}"
        exit 1
    fi

    cd ..
    echo "${GREEN}✅ Backend checks passed${NC}"
    echo ""
fi

# Frontend checks
if [ "$FRONTEND_CHANGED" -gt 0 ]; then
    echo "${YELLOW}📱 Frontend changes detected - running checks...${NC}"

    cd frontend

    echo "  → Running lint..."
    if ! npm run lint; then
        echo "${RED}❌ Frontend lint failed${NC}"
        exit 1
    fi

    echo "  → Running type check..."
    if ! npm run typecheck; then
        echo "${RED}❌ Frontend type check failed${NC}"
        exit 1
    fi

    echo "  → Running tests..."
    if ! npm test; then
        echo "${RED}❌ Frontend tests failed${NC}"
        exit 1
    fi

    cd ..
    echo "${GREEN}✅ Frontend checks passed${NC}"
    echo ""
fi

# Website checks
if [ "$WEBSITE_CHANGED" -gt 0 ]; then
    echo "${YELLOW}🌐 Website changes detected - running checks...${NC}"

    cd website

    echo "  → Running lint..."
    if ! npm run lint; then
        echo "${RED}❌ Website lint failed${NC}"
        exit 1
    fi

    cd ..
    echo "${GREEN}✅ Website checks passed${NC}"
    echo ""
fi

if [ "$BACKEND_CHANGED" -eq 0 ] && [ "$FRONTEND_CHANGED" -eq 0 ] && [ "$WEBSITE_CHANGED" -eq 0 ]; then
    echo "${GREEN}✅ No changes to check${NC}"
fi

echo ""
echo "${GREEN}🎉 All pre-commit checks passed!${NC}"
echo ""
